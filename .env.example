# Chatting Configuration
# Copy this file to .env and fill in your values

# Server port (default: 5001)
# PORT=5001

# Flask debug mode (default: true for development)
# Set to "0" or "false" in production
# FLASK_DEBUG=0

# Allowed CORS origins (comma-separated, default: all origins)
# Set to your frontend URL in production
# CORS_ORIGINS=http://localhost:5001
